# MySQL credentials (DEV ONLY)
MYSQL_ROOT_PASSWORD=dev_root_password_change_me
MYSQL_DATABASE=wine_store_db
MYSQL_USER=wine_user
MYSQL_PASSWORD=dev_db_password_change_me

# Spring datasource (DOCKER network)
DATASOURCE_URL=jdbc:mysql://db-sql:3306/wine_store_db?serverTimezone=UTC&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&useSSL=false
DATASOURCE_USER=wine_user
DATASOURCE_PASSWORD=dev_db_password_change_me

# Ports (host bindings)
DB_PORT=3309
BACKEND_PORT=8080
DEBUG_PORT=5006
ADMIN_UI_PORT=8081
FRONTEND_PORT=3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
ZIPKIN_PORT=9411
GRAFANA_PORT=3030

# Backend URLs
MAIN_BACKEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080/api
BACKEND_URL_DOCKER=http://api-backend:8080/api

# JWT configuration (DEV ONLY)
JWT_SECRET=dev-jwt-secret-change-me-please-min-32-chars
JWT_EXPIRATION=86400000

# Telegram bot config (disabled by default)
BOT_NAME=WineStoreBotDev
BOT_TOKEN=CHANGE_ME
TELEGRAM_BOT_ENABLED=false

# uploads (DOCKER)
UPLOAD_BASE_PATH=/app/uploads/
UPLOAD_CONFIG_BASE_PATH=file:/app/uploads/images/
IMAGE_SAVE_PATH=/app/uploads/images/wine/

# Observability / Tracing
MANAGEMENT_ZIPKIN_TRACING_ENDPOINT=http://tempo:9411/api/v2/spans
LOKI_URL=http://loki:3100/loki/api/v1/push