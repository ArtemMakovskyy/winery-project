### =========================
### CREATE WINE (POST x1)
### =========================
POST {{base_url}}/wines
Authorization: Bearer {{manager_token}}
Content-Type: application/json

{
  "vendorCode": "MSD {{$randomInt}}",
  "qualityLevel": "Premium",
  "reserveType": "Limited Edition Wine",
  "name": "Prince Trubetskoi Select Riesling",
  "shortName": "Prince Trubetskoi",
  "year": 2017,
  "tasteWine": "fish",
  "price": 25.59,
  "grape": "Riesling",
  "isDecantation": false,
  "wineType": "DRY",
  "strengthFrom": 10.9,
  "strengthTo": 11.8,
  "wineColor": "WHITE"
}


### =========================
### CREATE ORDER (POST x1)
### =========================
POST {{base_url}}/orders
Content-Type: application/json

{
  "userFirstAndLastName": "Ivan Petrov",
  "email": "customer@email.com",
  "phoneNumber": "+380509876543",
  "createShoppingCardDto": {
    "purchaseObjects": [
      {
        "wineId": 1,
        "quantity": 1
      }
    ]
  },
  "createOrderDeliveryInformationDto": {
    "zipCode": "00000",
    "region": "Kyiv region",
    "city": "Kyiv",
    "street": "Lobanovskogo str, 13/1, ap. 16",
    "comment": "string"
  }
}


