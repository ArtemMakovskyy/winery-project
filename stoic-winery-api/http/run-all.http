### =========================
### REGISTER USER (POST x1)
### =========================
POST {{auth_url}}/register
Content-Type: application/json

{
  "email": "tester{{$randomInt}}@example.com",
  "password": "password123",
  "repeatPassword": "password123",
  "firstName": "Ivan",
  "lastName": "Ivanov",
  "phoneNumber": "+380991112233"
}


### =========================
### LOGIN ADMIN
### =========================
POST {{auth_url}}/login
Content-Type: application/json

{
  "email": "{{admin_email}}",
  "password": "{{password}}"
}

> {%
    client.test("Admin login successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.global.set("admin_token", response.body.accessToken || response.body.token);
%}


### =========================
### LOGIN MANAGER
### =========================
POST {{auth_url}}/login
Content-Type: application/json

{
  "email": "{{manager_email}}",
  "password": "{{password}}"
}

> {%
    client.test("Manager login successful", function () {
        client.assert(response.status === 200, "Response status is not 200");
    });
    client.global.set("manager_token", response.body.accessToken || response.body.token);
%}


